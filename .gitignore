# Node.js

# Logs
logs/
*.log
npm-debug.log*

# Runtime data
pids/
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory used by tools like istanbul
coverage/

# The directory where application instrumentation is stored
.nyc_output/

# Grunt intermediate storage
.grunt/

# Bower dependency directory (for front-end dependencies)
bower_components/

# node-waf configuration
.lock-wscript

# IDEs and editors
.idea/
.vscode/

# Optional npm cache directory
.npm/

# Env files
.env
.env.local
.env.development
.env.test
.env.production
